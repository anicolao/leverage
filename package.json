{
  "name": "leverage-backtester-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "book:dev": "lits --serve",
    "book:build": "lits",
    "book:check": "npm run check && npm test && npm run book:build",
    "pages:build": "npm run build && npm run book:build && node scripts/prepare-pages.mjs"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.49.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^24.10.2",
    "litscript": "^2.4.0",
    "svelte": "^5.43.0",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.14"
  }
}
